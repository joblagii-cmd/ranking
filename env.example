# Copy this file to .env.local for local development
# Add these as Environment Variables in your Vercel project settings

# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# Your GitHub Personal Access Token
# Permissions needed: repo (read & write contents)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username or organization name
GITHUB_OWNER=your-github-username

# The repository where job posts will be saved
# Example: job-postings-india
GITHUB_REPO=job-postings-india

# Secret key to protect your cron and trigger endpoints
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-random-secret-here-change-this

# ─── OPTIONAL ──────────────────────────────────────────────────────────────────

# GitHub branch to commit to (default: main)
# GITHUB_BRANCH=main

# Set to "development" locally, Vercel auto-sets this in production
# NODE_ENV=development
